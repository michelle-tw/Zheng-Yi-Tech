rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.get('email', '').lower();
    }

    function isHardcodedAdmin() {
      let email = getEmail();
      return email == 'thanhhoa.tran10062001@gmail.com' || 
             email == 'jielun_0514@protheme.com';
    }

    function isSuperAdmin() {
      let email = getEmail();
      return isSignedIn() && (
        email == 'thanhhoa.tran10062001@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'GUEST') == 'SUPER_ADMIN')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isHardcodedAdmin() ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'GUEST') == 'ADMIN')
      );
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- Projects ---
    match /projects/{projectId} {
      // Projects must be visible to all employees for dashboard and selection
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['manual_progress']))
      );
    }

    // --- Timesheets ---
    match /timesheets/{timesheetId} {
      // Read: Admin sees all, User sees own
      allow get, list: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.user_id == request.auth.uid)
      );
      
      // Create: User can create for self, Admin for anyone
      allow create: if isSignedIn() && (
        request.resource.data.user_id == request.auth.uid || 
        isAdmin()
      );
      
      // Update: Admin can update anything. User can update their own UNLOCKED entries.
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.user_id == request.auth.uid && !resource.data.get('locked', false))
      );
      
      // Delete: Admin only
      allow delete: if isSignedIn() && isAdmin();
    }

    // --- Audit Logs ---
    match /audit_logs/{logId} {
      allow read: if isSignedIn() && isAdmin() && (
        isSuperAdmin() || resource.data.get('admin_role', '') != 'SUPER_ADMIN'
      );
      allow create: if isSignedIn();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
